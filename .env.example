# SalesMate AI Configuration
# Copy this file to .env and fill in your values

# ====================
# LLM Provider Settings
# ====================
# Supported providers: openai, anthropic, azure, custom
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ====================
# Feishu (飞书) Settings
# ====================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ALLOW_FROM=

# ====================
# DingTalk (钉钉) Settings
# ====================
DINGTALK_CLIENT_ID=
DINGTALK_SECRET=
DINGTALK_ALLOW_FROM=

# ====================
# WeCom (企业微信) Settings
# ====================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_ALLOW_FROM=

# ====================
# Telegram Settings
# ====================
TELEGRAM_TOKEN=
TELEGRAM_ALLOW_FROM=

# ====================
# Discord Settings
# ====================
DISCORD_TOKEN=
DISCORD_ALLOW_FROM=

# ====================
# Slack Settings
# ====================
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOW_FROM=

# ====================
# WhatsApp Settings
# ====================
WHATSAPP_ENABLED=false
WHATSAPP_ALLOW_FROM=

# ====================
# Email Settings
# ====================
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_ALLOW_FROM=

# ====================
# Database Settings
# ====================
DATABASE_URL=postgres://salesmate:salesmate@localhost:5432/salesmate?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# ====================
# Vector Store Settings (RAG)
# ====================
VECTOR_STORE_TYPE=qdrant
VECTOR_STORE_URL=http://localhost:6333
VECTOR_STORE_COLLECTION=salesmate_kb
VECTOR_STORE_EMBEDDING_MODEL=text-embedding-ada-002

# ====================
# Gateway Settings
# ====================
GATEWAY_PORT=18790
GATEWAY_HEARTBEAT_INTERVAL=3600
GATEWAY_HEARTBEAT_ENABLED=true

# ====================
# Agent Settings
# ====================
AGENT_MAX_ITERATIONS=10
AGENT_MEMORY_WINDOW=20
AGENT_WORKSPACE=./workspace

# ====================
# Security Settings
# ====================
SECURITY_STRICT_MODE=true
SECURITY_EMOTION_THRESHOLD=0.7
SECURITY_AUTO_REPLY_ENABLED=true

# ====================
# Sales Settings
# ====================
SALES_FOLLOWUP_INTERVAL_HOURS=24
SALES_MAX_FOLLOWUP_COUNT=5
SALES_QUALIFIED_LEAD_THRESHOLD=0.6

# ====================
# Logging Settings
# ====================
LOG_LEVEL=info
LOG_FORMAT=json